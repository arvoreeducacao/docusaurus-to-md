{
  "name": "docusaurus-to-md",
  "version": "0.1.0",
  "description": "Scrape Docusaurus sites and convert to clean Markdown files",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "docusaurus-to-md": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "docusaurus",
    "markdown",
    "scraper",
    "documentation"
  ],
  "author": "Árvore",
  "license": "MIT",
  "packageManager": "pnpm@10.28.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/arvoreeducacao/docusaurus-to-md"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/turndown": "^5.0.5",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  }
}
